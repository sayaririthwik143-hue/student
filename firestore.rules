rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, displayName, email, photoURL, disciplineScore, studyGoal, dailyTargetMinutes, badges, createdAt
    
    // Collection: users/{userId}/tasks
    // Fields: id, userId, title, category, priority, deadline, completed, createdAt
    
    // Collection: users/{userId}/studySessions
    // Fields: id, userId, subject, durationMinutes, mode, timestamp
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['userId', 'title', 'category']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['userId', 'durationMinutes', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.durationMinutes is int;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);

      match /tasks/{taskId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTask(request.resource.data);
        allow update: if isOwner(userId) && isValidTask(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /studySessions/{sessionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSession(request.resource.data);
      }
    }
  }
}
