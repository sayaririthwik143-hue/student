# GEMINI_API_KEY: Required for Gemini AI API calls.
# On Vercel or Netlify, add this to your Environment Variables in the project settings.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Firebase Configuration (Client-side, prefixed with VITE_)
VITE_FIREBASE_API_KEY="your_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your_firebase_auth_domain"
VITE_FIREBASE_PROJECT_ID="your_firebase_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_firebase_storage_bucket"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_firebase_messaging_sender_id"
VITE_FIREBASE_APP_ID="your_firebase_app_id"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="your_firebase_firestore_database_id"

# APP_URL: The URL where your app is hosted (e.g., https://your-app.netlify.app).
# Used for self-referential links and OAuth callbacks.
APP_URL="YOUR_APP_URL"
